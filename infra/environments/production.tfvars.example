aws_region   = "ap-southeast-2"
project_name = "portfolio"

azs                  = ["ap-southeast-2a", "ap-southeast-2b", "ap-southeast-2c"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]

single_nat_gateway = true

tags = {
  Environment = "production"
  Project     = "portfolio"
}

# Custom domain - set BOTH (get zone ID from Route 53 → Hosted zones)
# Frontend: roshan-shrestha.com, www | Backend API: api.roshan-shrestha.com
domain_name     = "roshan-shrestha.com"
route53_zone_id = "Z0123456789ABCDEFGHIJ"  # MUST be your real zone ID - run: aws route53 list-hosted-zones --query "HostedZones[?Name=='roshan-shrestha.com.'].Id" --output text

# Database - required for backend (Neon, Supabase, or RDS)
# database_url = "postgresql://user:pass@host:5432/portfolio"

# GitHub secret VITE_API_URL for frontend build (default: https://api.roshan-shrestha.com)
